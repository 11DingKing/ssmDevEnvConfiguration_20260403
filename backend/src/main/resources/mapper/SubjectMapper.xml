<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.mapper.SubjectMapper">

    <select id="findAll" resultType="Subject">
        SELECT * FROM subject ORDER BY id
    </select>

    <select id="findById" resultType="Subject">
        SELECT * FROM subject WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Subject" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO subject(subject_name) VALUES(#{subjectName})
    </insert>

    <delete id="deleteById">
        DELETE FROM subject WHERE id = #{id}
    </delete>
</mapper>

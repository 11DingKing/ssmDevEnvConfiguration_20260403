# 数据库连接配置示例
# 复制此文件为 .env 并修改为实际配置
# 注意：.env 文件已添加到 .gitignore，不会被 Git 跟踪

# 数据库驱动
DB_DRIVER=com.mysql.cj.jdbc.Driver

# 数据库连接 URL
# 本地开发环境示例：jdbc:mysql://localhost:3306/exam_system?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
# Docker 环境示例：jdbc:mysql://mysql:3306/exam_system?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_URL=jdbc:mysql://localhost:3306/exam_system?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# 数据库用户名
DB_USERNAME=root

# 数据库密码
DB_PASSWORD=your_secure_password
